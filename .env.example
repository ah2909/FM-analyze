APP_ENV=development
PORT=7070
HOST=0.0.0.0

# Google Gemini (required)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash

# CoinGecko (optional — free tier works without key, but rate-limited)
COINGECKO_API_KEY=your_coingecko_api_key_here
COINGECKO_HISTORY_DAYS=90

# LLM tuning
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=8192

# Graph execution
GRAPH_TIMEOUT=90
ANALYSIS_CACHE_TTL=300
