APP_ENV=development
PORT=7070
HOST=0.0.0.0

# Google Gemini (required)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini_model

# CoinGecko (optional — free tier works without key, but rate-limited)
COINGECKO_API_KEY=your_coingecko_api_key_here
# true if using a paid/Pro key (uses x-cg-pro-api-key instead of the demo header)
COINGECKO_PRO=false
COINGECKO_HISTORY_DAYS=30

# LLM tuning
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=8192

# Research-outlook pipeline (per-symbol; caching is handled by the backend)
RESEARCH_NEWS_RECENCY_DAYS=60
RESEARCH_MAX_CONCURRENCY=5

BACKEND_URL=
FRONTEND_URL=